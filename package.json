{
  "name": "quickhub",
  "version": "1.1.0",
  "description": "Hub de Acessos Rápidos para empresa",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "icon": "node create-ico.js",
    "build": "node create-ico.js && electron-builder --win",
    "build:portable": "node create-ico.js && electron-builder --win portable"
  },
  "author": "QuickHub",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "build": {
    "appId": "com.quickhub.app",
    "productName": "QuickHub",
    "forceCodeSigning": false,
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable",
        "nsis"
      ],
      "signAndEditExecutable": false,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "QuickHub",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "artifactName": "QuickHub-Setup-v${version}.exe"
    },
    "portable": {
      "artifactName": "QuickHub-v${version}-win-x64.exe"
    },
    "files": [
      "src/**/*",
      "config/**/*",
      "resources/**/*"
    ]
  }
}
